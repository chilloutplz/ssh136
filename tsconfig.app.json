{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "strict": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,

    // alias 인식 핵심
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    // 프로젝트 참조 필수
    "composite": true
  },
  "include": ["src"]
}
